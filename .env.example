# Application
NODE_ENV=development
SECRET_KEY=change-me-to-a-long-random-string
CORS_ORIGIN=http://localhost:8080

# Server database: mysql or postgres
DB_TYPE=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=secret
DB_NAME=bingo

# For PostgreSQL instead, use:
# DB_TYPE=postgres
# DB_PORT=5432

# Redis (cache + optional Socket.IO scaling)
REDIS_HOST=localhost
REDIS_PORT=6379

# Admin bootstrap (first run only — required in production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Client (Vue)
VUE_APP_API_URL=http://localhost:3000
